  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "pin-actions@intility-claude-plugins": true,
    "dotnet-pr-review@intility-claude-plugins": false,
    "intility-design-companion@intility-claude-plugins": true,
